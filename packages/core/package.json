{
  "name": "@shardix/core",
  "version": "0.5.0",
  "description": "Core architecture, IoC container and application factory for Shardix Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@shardix/common": "workspace:*",
    "@shardix/http": "workspace:*",
    "@shardix/transport": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@swc/core": "^1.15.46",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.8"
  }
}
